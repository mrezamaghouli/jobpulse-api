# =============================================================================
# JobPulse API - Example Environment
# Copy this file to .env and change real secrets before running production.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME=JobPulse API
APP_VERSION=1.0.0
APP_ENV=development

PORT=8000
JOB_PROVIDER=json

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

API_KEY=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# PostgreSQL
# For Docker Compose use: POSTGRES_HOST=db
# For local PowerShell scripts use: POSTGRES_HOST=127.0.0.1
# -----------------------------------------------------------------------------
POSTGRES_DB=jobpulse
POSTGRES_USER=jobpulse_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# LinkedIn Collector - Basic Search Defaults
# -----------------------------------------------------------------------------
LINKEDIN_BROWSER=chrome
LINKEDIN_KEYWORDS=UX Designer
LINKEDIN_LOCATION=Germany
LINKEDIN_LIMIT=20
LINKEDIN_MAX_PAGES=3
LINKEDIN_LOOKBACK_DAYS=30
LINKEDIN_WORK_MODE=

# -----------------------------------------------------------------------------
# LinkedIn Collector - Safety / Smart Search
# -----------------------------------------------------------------------------
LINKEDIN_QUERY_COOLDOWN_HOURS=12
LINKEDIN_SKIP_EXISTING_ENRICHED=true
LINKEDIN_QUERY_RETRY_COUNT=1
LINKEDIN_QUERY_RETRY_DELAY_SECONDS=10
LINKEDIN_STOP_AFTER_NO_NEW_SCROLLS=2

# Optional: smart planner output file
LINKEDIN_QUERIES_FILE=config/linkedin_smart_queries.json

# -----------------------------------------------------------------------------
# LinkedIn Scheduling / Legacy Settings
# -----------------------------------------------------------------------------
LINKEDIN_STALE_DAYS=7
LINKEDIN_SCHEDULE_INTERVAL_MINUTES=180

# -----------------------------------------------------------------------------
# Company Enrichment
# -----------------------------------------------------------------------------
COMPANY_ENRICH_LIMIT=3
COMPANY_ENRICH_STALE_DAYS=30

# -----------------------------------------------------------------------------
# Job Lifecycle
# active -> inactive -> archived
# Hard delete should stay false until production backups exist.
# -----------------------------------------------------------------------------
JOB_INACTIVE_AFTER_DAYS=30
JOB_ARCHIVE_AFTER_DAYS=60
JOB_HARD_DELETE_ENABLED=false
JOB_HARD_DELETE_AFTER_DAYS=120

# -----------------------------------------------------------------------------
# Production Collection Runner Defaults
# safe / balanced / strong are selected by CLI argument, not env.
# -----------------------------------------------------------------------------
PRODUCTION_COLLECTION_PROFILE=balanced